# 应用基础信息：用于区分服务名称、运行环境和调试模式
APP_NAME=LLM-SafetyHub
ENVIRONMENT=production
DEBUG=false

# 上游中转站配置：SafetyHub 会把通过安全检查的请求转发到这里
UPSTREAM_URL=https://yxai-api.nanfu.com
UPSTREAM_TIMEOUT_CONNECT=10
UPSTREAM_TIMEOUT_READ=300
UPSTREAM_TIMEOUT_POOL=10
UPSTREAM_MAX_CONNECTIONS=300
UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=200
UPSTREAM_KEEPALIVE_EXPIRY=30

# /v1 接口并发保护：超过在途和队列上限会返回 429，避免服务被压垮
V1_MAX_INFLIGHT=250
V1_MAX_QUEUE_SIZE=500
V1_QUEUE_TIMEOUT_SECONDS=30

# 管理后台统计缓存：降低后台统计接口对数据库的查询压力
ADMIN_STATS_CACHE_SECONDS=15

# 归档队列配置：控制请求/响应归档的后台写入节奏和单条归档体积
ARCHIVE_QUEUE_MAX_SIZE=10000
ARCHIVE_BATCH_SIZE=100
ARCHIVE_FLUSH_INTERVAL_SECONDS=1
ARCHIVE_MAX_PAYLOAD_BYTES=262144
STREAM_ARCHIVE_MAX_BYTES=1048576

# 规则配置：安全规则文件路径和热加载间隔
RULES_CONFIG_PATH=engine/rules_config.yaml
RULES_RELOAD_INTERVAL=5
SAFETYHUB_RULES_CONFIG=./engine/rules_config.yaml

# Docker Compose 对外端口：内网用户访问 http://内网服务器IP:8080/admin/
SAFETYHUB_HTTP_PORT=8080

# 离线镜像配置：内网服务器不构建镜像，只使用 safetyhub-images.tar 中导入的镜像
SAFETYHUB_IMAGE=nf-safetyhub-safetyhub:latest
SAFETYHUB_SKIP_BUILD=true

# 数据盘路径：如果内网服务器的数据盘不是 /data/safetyhub，只改这三个路径
SAFETYHUB_DATA_ROOT=/data/safetyhub
SAFETYHUB_DATA_DIR=/data/safetyhub/app
SAFETYHUB_POSTGRES_DATA_DIR=/data/safetyhub/postgres

# PostgreSQL 配置：Compose 内部数据库服务名固定为 postgres
POSTGRES_DB=safetyhub
POSTGRES_USER=safetyhub
POSTGRES_PASSWORD=change-me-in-local-env
DB_URL=postgresql+asyncpg://safetyhub:change-me-in-local-env@postgres:5432/safetyhub
POSTGRES_DB_URL=postgresql+asyncpg://safetyhub:change-me-in-local-env@postgres:5432/safetyhub

# 数据保留周期：审计和归档数据的保留天数
ARCHIVE_RETENTION_DAYS=180
AUDIT_RETENTION_DAYS=365

# 数据加密配置：当前保持和现有环境一致，未启用加密
DATA_ENCRYPTION_ENABLED=false
DATA_ENCRYPTION_KEY_ENV=SAFETYHUB_DATA_KEY
SAFETYHUB_DATA_KEY=change-me-in-local-env

# API Key 策略：生产/内网环境不允许空 API Key 透传
ALLOW_EMPTY_API_KEYS_PASSTHROUGH=false

# OneAPI Key Provider 配置：保持和当前测试环境同一个上游中转站与账号
KEY_PROVIDER_TYPE=oneapi_nanfu_yxai
KEY_PROVIDER_ADMIN_TOKEN=
KEY_PROVIDER_BASE_URL=https://yxai-api.nanfu.com
KEY_PROVIDER_USERNAME=800585
KEY_PROVIDER_PASSWORD_ENV=KEY_PROVIDER_PASSWORD
KEY_PROVIDER_PASSWORD=Ab123456
KEY_PROVIDER_AUTH_VERSION=864b7076dbcd0a3c01b5520316720ebf
KEY_PROVIDER_DEFAULT_REMAIN_QUOTA=1000000
KEY_PROVIDER_DEFAULT_UNLIMITED_QUOTA=true
KEY_PROVIDER_TIMEOUT_SECONDS=30
KEY_PROVIDER_LOGIN_RETRIES=3
KEY_PROVIDER_LOGIN_RETRY_DELAY_SECONDS=10
KEY_PROVIDER_REQUEST_RETRIES=3
KEY_PROVIDER_REQUEST_RETRY_DELAY_SECONDS=2

# 管理后台登录配置：用于访问 /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-local-env
ADMIN_IP_WHITELIST=[]

# 告警和审批 Webhook：为空表示不启用对应通知
WEBHOOK_URL=
WEBHOOK_TYPE=wecom
APPROVAL_WEBHOOK_URL=
APPROVAL_TIMEOUT_MINUTES=30
ALERT_SILENCE_RULE_MINUTES=5
ALERT_SILENCE_USER_MINUTES=2
ALERT_HOURLY_LIMIT=50

# 请求体与文件扫描限制：控制上传和文件扫描能力
REQUEST_MAX_BODY_MB=20
FILE_SCAN_ENABLED=false
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_TYPES=["txt","md","pdf","docx","xlsx","csv"]

# Uvicorn 容器内部启动配置：容器内监听 8000，由 Nginx 对外代理到 SAFETYHUB_HTTP_PORT
UVICORN_WORKERS=4
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
