APP_NAME=LLM-SafetyHub
ENVIRONMENT=development
DEBUG=true

UPSTREAM_URL=https://example-upstream.local
UPSTREAM_TIMEOUT_CONNECT=10
UPSTREAM_TIMEOUT_READ=300
UPSTREAM_TIMEOUT_POOL=10
UPSTREAM_MAX_CONNECTIONS=300
UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=200
UPSTREAM_KEEPALIVE_EXPIRY=30

V1_MAX_INFLIGHT=250
V1_MAX_QUEUE_SIZE=500
V1_QUEUE_TIMEOUT_SECONDS=30
ADMIN_STATS_CACHE_SECONDS=15
ARCHIVE_QUEUE_MAX_SIZE=10000
ARCHIVE_BATCH_SIZE=100
ARCHIVE_FLUSH_INTERVAL_SECONDS=1
ARCHIVE_MAX_PAYLOAD_BYTES=262144

RULES_CONFIG_PATH=engine/rules_config.yaml
RULES_RELOAD_INTERVAL=5

DB_URL=sqlite+aiosqlite:///./data/safetyhub.db
ARCHIVE_RETENTION_DAYS=180
AUDIT_RETENTION_DAYS=365
DATA_ENCRYPTION_ENABLED=false
DATA_ENCRYPTION_KEY_ENV=SAFETYHUB_DATA_KEY

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-local-env
ADMIN_IP_WHITELIST=[]

WEBHOOK_URL=
WEBHOOK_TYPE=wecom
APPROVAL_WEBHOOK_URL=
APPROVAL_TIMEOUT_MINUTES=30
ALERT_SILENCE_RULE_MINUTES=5
ALERT_SILENCE_USER_MINUTES=2
ALERT_HOURLY_LIMIT=50

REQUEST_MAX_BODY_MB=20
FILE_SCAN_ENABLED=false
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_TYPES=["txt","md","pdf","docx","xlsx","csv"]

UVICORN_WORKERS=1
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
