APP_NAME=LLM-SafetyHub
ENVIRONMENT=development
DEBUG=true

UPSTREAM_URL=https://yxai-api.nanfu.com
UPSTREAM_TIMEOUT_CONNECT=10
UPSTREAM_TIMEOUT_READ=120

RULES_CONFIG_PATH=engine/rules_config.yaml
RULES_RELOAD_INTERVAL=5

DB_URL=sqlite+aiosqlite:///./data/safetyhub.db
ARCHIVE_RETENTION_DAYS=180
AUDIT_RETENTION_DAYS=365
DATA_ENCRYPTION_ENABLED=false
DATA_ENCRYPTION_KEY_ENV=SAFETYHUB_DATA_KEY
ALLOW_EMPTY_API_KEYS_PASSTHROUGH=true
STREAM_ARCHIVE_MAX_BYTES=1048576
KEY_PROVIDER_TYPE=oneapi_nanfu_yxai
KEY_PROVIDER_ADMIN_TOKEN=
KEY_PROVIDER_BASE_URL=https://yxai-api.nanfu.com
KEY_PROVIDER_USERNAME=800585
KEY_PROVIDER_PASSWORD_ENV=KEY_PROVIDER_PASSWORD
KEY_PROVIDER_PASSWORD=Ab123456
KEY_PROVIDER_AUTH_VERSION=864b7076dbcd0a3c01b5520316720ebf
KEY_PROVIDER_DEFAULT_REMAIN_QUOTA=1000000
KEY_PROVIDER_DEFAULT_UNLIMITED_QUOTA=true
KEY_PROVIDER_TIMEOUT_SECONDS=30
KEY_PROVIDER_LOGIN_RETRIES=3
KEY_PROVIDER_LOGIN_RETRY_DELAY_SECONDS=10
KEY_PROVIDER_REQUEST_RETRIES=3
KEY_PROVIDER_REQUEST_RETRY_DELAY_SECONDS=2

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-local-env
ADMIN_IP_WHITELIST=[]

WEBHOOK_URL=
WEBHOOK_TYPE=wecom
APPROVAL_WEBHOOK_URL=
APPROVAL_TIMEOUT_MINUTES=30
ALERT_SILENCE_RULE_MINUTES=5
ALERT_SILENCE_USER_MINUTES=2
ALERT_HOURLY_LIMIT=50

REQUEST_MAX_BODY_MB=20
FILE_SCAN_ENABLED=false
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_TYPES=["txt","md","pdf","docx","xlsx","csv"]

UVICORN_WORKERS=4
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
